{
  "permissions": {
    "allow": [
      "Edit(*)",
      "Write(*)",
      "NotebookEdit(*)",
      "Bash(bash *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(python3 *)",
      "Bash(git *)",
      "Bash(codex *)",
      "Bash(find *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(tail *)",
      "Bash(mkdir *)",
      "Bash(test *)",
      "WebFetch(domain:*)",
      "WebSearch",
      "mcp__*"
    ],
    "deny": [],
    "ask": [
      "Bash(rm *)",
      "Bash(rmdir *)",
      "Bash(shred *)",
      "Bash(unlink *)",
      "Bash(dd *)",
      "Bash(mkfs *)",
      "Bash(fdisk *)",
      "Bash(chmod 777 *)",
      "Bash(chown *)",
      "Bash(kill *)",
      "Bash(killall *)",
      "Bash(pkill *)"
    ]
  },
  "plansDirectory": "./docs/plans",
  "outputStyle": "Explanatory",
  "respectGitignore": true,
  "env": {
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "80"
  },
  "enableAllProjectMcpServers": true,
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "matcher": "Bash(rm -rf)|Bash(rm -r /)|Bash(rm /*)",
            "type": "prompt",
            "prompt": "DANGER: This command may delete critical files. Approve only with explicit user confirmation. Reason: "
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "matcher": "Bash(rm |rmdir |shred )",
            "type": "prompt",
            "prompt": "This command modifies the filesystem. Ask user to confirm: "
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "prompt",
            "prompt": "Before stopping: Did you run tests? Is the work committed?"
          }
        ]
      }
    ]
  }
}
