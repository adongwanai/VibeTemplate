{
  "permissions": {
    "allow": [
      "Edit(*)",
      "Write(*)",
      "NotebookEdit(*)",
      "Bash(*)",
      "WebFetch(domain:*)",
      "WebSearch",
      "mcp__*"
    ],
    "deny": [],
    "ask": []
  },
  "plansDirectory": "./docs/plans",
  "outputStyle": "Explanatory",
  "respectGitignore": true,
  "env": {
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "80",
    "CLAUDE_PERMISSION_MODE": "dangerously-skip-permissions"
  },
  "enableAllProjectMcpServers": true,
  "hooks": {}
}
